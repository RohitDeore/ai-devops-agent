# ============================================================
#  AI DevOps Incident Response Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

# --- Flask ---
FLASK_ENV=development          # development | production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false              # true only in development

# --- API Security ---
# A long random string used to authenticate API requests.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change_me_to_a_random_secret

# --- Log File ---
LOG_FILE_PATH=logs/app.log

# --- Agent Behaviour ---
SIMULATION_MODE=true           # true = no real infra calls
USE_AI_REASONING=false         # true = use OpenAI for RCA

# --- OpenAI (only needed when USE_AI_REASONING=true) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Microsoft Azure AI Foundry (multi-step reasoning agent) ---
# Set USE_FOUNDRY=true to enable. Takes priority over USE_AI_REASONING.
USE_FOUNDRY=false
AZURE_FOUNDRY_ENDPOINT=https://<your-hub>.openai.azure.com/
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_DEPLOYMENT=gpt-4o-mini        # your Azure deployment name
AZURE_FOUNDRY_API_VERSION=2024-12-01-preview

# --- Report Persistence ---
REPORTS_DIR=reports            # directory where JSON reports are saved

# --- Rate Limiting ---
# Requests per minute per IP for the /analyze endpoint
RATE_LIMIT=60

# --- Production Infrastructure (only used when SIMULATION_MODE=false) ---
KUBERNETES_NAMESPACE=default
PAGERDUTY_ROUTING_KEY=
SLACK_WEBHOOK_URL=
AWS_REGION=us-east-1
